            "url": {
              "raw": "{{baseUrl}}/roles",
              "host": ["{{baseUrl}}"],
              "path": ["roles"]
            }
          }
        },
        {
          "name": "Actualizar rol",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"MODERADOR\",\n  \"descripcion\": \"Rol con permisos de moderación actualizados\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/roles/3",
              "host": ["{{baseUrl}}"],
              "path": ["roles", "3"]
            }
          }
        },
        {
          "name": "Eliminar rol",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/roles/3",
              "host": ["{{baseUrl}}"],
              "path": ["roles", "3"]
            }
          }
        }
      ]
